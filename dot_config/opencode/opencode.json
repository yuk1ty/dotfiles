{
	"$schema": "https://opencode.ai/config.json",
	"theme": "catppuccin",
	"formatter": true,
	"lsp": {
		"kotlin-ls": {
			"disabled": true
		},
		"kotlin": {
			"command": ["kotlin-lsp", "--stdio"],
			"extensions": [".kt", ".kts"]
		}
	},
	"permission": {
		"task": {
			"*": "allow"
		},
		"bash": {
			"git *": "allow",
			"gh *": "allow",
			"rm *": "ask"
		},
		"external_directory": {
			"/tmp/**": "allow"
		},
		"read": {
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow"
		}
	}
}
